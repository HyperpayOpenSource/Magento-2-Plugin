            https://pay.google.com
            https://applepay.cdn-apple.com
            https://cdn10.ebuckler.com
            https://stats.ebuckler.com
            https://*.masterpass.com
            'nonce-${nonce}'
            'unsafe-eval';
        connect-src 'self'
            https://${domain}
            https://p11.techlab-cdn.com
            https://*.iovation.com
            https://*.klarnacdn.net
            https://*.paypal.com
            https://*.affirm.com
            https://*.payments-amazon.com
            https://*.oney.io
