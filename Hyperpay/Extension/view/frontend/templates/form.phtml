            https://pay.google.com
            https://applepay.cdn-apple.com
            https://cdn10.ebuckler.com
            https://stats.ebuckler.com
            https://*.masterpass.com;
        script-src 'self'
            https://${domain}
            https://*.iovation.com
            https://*.klarnacdn.net
